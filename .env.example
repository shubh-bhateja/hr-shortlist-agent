# ──────────────────────────────────────────────
# HR Shortlisting Agent – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# Choose ONE: "openai" (paid) or "gemini" (FREE tier)
LLM_PROVIDER=gemini

# OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...your-key-here...

# Google Gemini (FREE: 15 RPM, 1M tokens/day)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=...your-free-key-here...
GEMINI_MODEL=gemini-2.5-flash

# LangSmith Observability (optional but recommended for bonus marks)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...your-key-here...
LANGCHAIN_PROJECT=hr-shortlist-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# App Settings
LOG_LEVEL=INFO
MAX_RESUMES_PER_RUN=20
DRY_RUN=false
